# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ---- Frontend ----
VITE_API_BASE_URL=http://localhost:8000/api

# ---- External Providers ----
OPENAI_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- SendGrid ----
SENDGRID_API_KEY=
SENDGRID_FROM=