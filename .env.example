# ---- Global ----
COMPOSE_PROJECT_NAME=flowpilot

# ---- Backend ----
APP_NAME=FlowPilot API
APP_ENV=development
APP_PORT=8000

# ---- PostgreSQL ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
