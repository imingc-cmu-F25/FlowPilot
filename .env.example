# ---- Global ----
COMPOSE_PROJECT_NAME=flowpilot

# ---- Backend ----
APP_NAME=FlowPilot API
APP_ENV=development
APP_PORT=8000

# ---- PostgreSQL ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=flowpilot
POSTGRES_USER=flowpilot
POSTGRES_PASSWORD=flowpilot

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ---- Frontend ----
# Local dev talks to the backend directly on :8000.
# In prod behind Caddy, the frontend Dockerfile.prod hardcodes this to `/api`
# (same-origin), so the value below is only used for `make up` / local dev.
VITE_API_BASE_URL=http://localhost:8000/api

# ---- Deployment (production only) ----
# Public domain pointed at the EC2 elastic IP.
# Caddy uses this to issue a Let's Encrypt TLS certificate automatically.
DOMAIN=flowpilot.example.com
CADDY_EMAIL=

# ---- External Providers ----
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# Google OAuth — required for the real Google Calendar connector.
# Register an OAuth 2.0 Web application in the Google Cloud Console
# and add GOOGLE_REDIRECT_URI below as an authorized redirect URI.
# If left blank, CalendarCreateEvent actions will fall back to mock events.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must exactly match the URI registered on the Google OAuth client.
GOOGLE_REDIRECT_URI=http://localhost:8000/api/connectors/google/callback
# Where users land after completing Google OAuth (frontend /profile page).
FRONTEND_BASE_URL=http://localhost:5173

# ---- Action isolation ----
# When true, the engine worker dispatches each action to the dedicated
# "actions" Celery queue (see the action-worker service in the compose
# files). Leave false for single-process dev/test setups.
ACTION_WORKER_ENABLED=false

# ---- SendGrid ----
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=
SMTP_FROM=