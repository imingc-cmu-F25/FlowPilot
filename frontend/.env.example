# Production only: set the deployed API base URL (must include /api).
# In dev, leave unset — the Vite proxy forwards /api/* to the backend (no CORS).
# VITE_API_BASE_URL=https://api.example.com/api

# Dev only: override the Vite proxy target (defaults to http://localhost:8000).
# Set to http://backend:8000 when running inside Docker Compose.
# VITE_API_PROXY_TARGET=http://localhost:8000
